# This is the root configuration file for the project
root = true

# LISA Edge deploys to Linux hosts: LF is the default for every file.
# Windows-only helper scripts are the explicit exception below.
[*]
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

[*.{bat,cmd,ps1}]
end_of_line = crlf

[{user-data,compose.yml,*.json}]
indent_size = 2
