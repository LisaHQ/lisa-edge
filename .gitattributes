# Normalize all text files to LF in the repository and in the working tree.
# LISA Edge runs on Linux hosts; CRLF in shell scripts, env files, YAML,
# systemd units, or cloud-init seeds breaks deployment.
* text=auto eol=lf

# Windows-only helper scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Never let these drift, even on Windows checkouts.
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.template  text eol=lf
user-data   text eol=lf
meta-data   text eol=lf
grub.cfg    text eol=lf
