###############################################################################
# LISA Edge - Environment Template
###############################################################################
# LISA Edge is a hardware-agnostic Linux infrastructure stack.
#
# It can run on ZimaBoard, Raspberry Pi, Intel NUC, mini PC, generic x86-64
# Linux server, or a VM. ZimaBoard 2 is only the reference platform.
###############################################################################
LISA_EDGE_HOSTNAME=lisa-edge-01
TZ=America/Los_Angeles
DATA_ROOT=/srv/lisa-edge
BACKUP_DEST=/srv/lisa-edge/backups
BACKUP_RETENTION_DAYS=14
# Set to 1 for NAS/external destinations. Backup will fail instead of writing
# to the local root filesystem when the expected mount is absent.
BACKUP_REQUIRE_MOUNT=0
# Optional findmnt SOURCE value, for example nas:/volume/lisa-edge.
BACKUP_EXPECTED_MOUNT_SOURCE=
# Read directly by Docker Compose itself (not by LISA scripts) to name the stack.
COMPOSE_PROJECT_NAME=lisa-edge
# missing: use local images and pull only when absent (recommended default)
# always:  explicitly refresh images on every deployment
# never:   require all images to exist locally
LISA_PULL_POLICY=missing

###############################################################################
# Container Image References
###############################################################################
# Override these with release tags or multi-architecture manifest digests for
# a fully reproducible production deployment. Image refresh is controlled by
# LISA_PULL_POLICY and `./lisa-edge update`.
###############################################################################
# Set to 1 to reject selected images that are not pinned with @sha256 digest.
LISA_REQUIRE_PINNED_IMAGES=0
MQTT_IMAGE=eclipse-mosquitto:2
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:1
OTBR_IMAGE=openthread/border-router:latest
TAILSCALE_IMAGE=tailscale/tailscale:latest
HOME_ASSISTANT_IMAGE=ghcr.io/home-assistant/home-assistant:stable
ZIGBEE2MQTT_IMAGE=koenkk/zigbee2mqtt:latest
NODE_RED_IMAGE=nodered/node-red:latest

###############################################################################
# Network Bind Addresses
###############################################################################
# Defaults are localhost-only. Set a trusted service/admin IP when LAN clients
# need access. Avoid 0.0.0.0 unless firewall policy explicitly protects it.
###############################################################################
MQTT_BIND_ADDR=127.0.0.1
UPTIME_KUMA_BIND_ADDR=127.0.0.1
ZIGBEE2MQTT_BIND_ADDR=127.0.0.1
NODE_RED_BIND_ADDR=127.0.0.1
# auto checks each service through its configured bind address. A 0.0.0.0 bind
# is checked through 127.0.0.1.
HEALTHCHECK_BIND_ADDR=auto

###############################################################################
# Service Ports
###############################################################################
MQTT_PORT=1883
MQTT_WS_PORT=9001
UPTIME_KUMA_PORT=3001
ZIGBEE2MQTT_PORT=8080
NODE_RED_PORT=1880
# Healthcheck-only: Home Assistant uses network_mode host and always listens
# on its configured port (default 8123). Change this ONLY if you changed the
# port inside Home Assistant itself; it does not remap the port.
HOME_ASSISTANT_PORT=8123

###############################################################################
# MQTT
###############################################################################
# Change MQTT_PASSWORD before production use.
###############################################################################
MQTT_USERNAME=lisa
MQTT_PASSWORD=change-this-password

###############################################################################
# Optional Service Profiles
###############################################################################
# Space-separated list of services to enable. Select one, multiple, or all.
# The provisioning wizard automatically adds required dependencies.
#
# Current options:
#   mqtt
#   uptime-kuma
#   otbr
#   vpn-tailscale
#   ha
#   zigbee2mqtt
#   node-red
#
# Example:
#   LISA_COMPOSE_SERVICES="mqtt uptime-kuma otbr vpn-tailscale"
###############################################################################
LISA_COMPOSE_SERVICES="mqtt uptime-kuma"

# Host-level Thread preparation is only needed when running OTBR on this host.
# It installs Avahi and enables IPv6 forwarding.
LISA_ENABLE_THREAD_HOST_PREP=0

###############################################################################
# Thread Border Router (OTBR) - Optional
###############################################################################
# Enable only if this host will run OpenThread Border Router.
#
# Find YOUR_THREAD_RCP_RADIO with:
#   ls -l /dev/serial/by-id/
#
# Backbone interface should be the service-facing NIC on VLAN_SVC or VLAN_CTRL path.
###############################################################################
THREAD_RADIO_DEVICE=/dev/serial/by-id/YOUR_THREAD_RCP_RADIO
THREAD_RADIO_URL=spinel+hdlc+uart:///dev/ttyThreadRCP?uart-baudrate=460800
OTBR_BACKBONE_IF=enp1s0
OTBR_THREAD_IF=wpan0
OTBR_LOG_LEVEL=5
OTBR_DATASET_BACKUP_DIR=/srv/lisa-edge/backups/otbr
OTBR_DATASET_LATEST=/srv/lisa-edge/backups/otbr/latest.dataset.hex
OTBR_DATASET_RETENTION_DAYS=30

# Automatically restore the most recent Thread dataset backup if OTBR starts
# with an empty configuration.
#
# Recommended: 1
OTBR_AUTO_RESTORE_DATASET=1

# Automatically create a brand-new Thread network if no dataset exists.
#
# WARNING:
# DO NOT enable this by default in production.
#
# If enabled, a fresh Thread dataset may be generated during deployment,
# causing all existing Matter-over-Thread devices to lose connectivity.
#
# Recommended:
#   Production = 0
#   Lab/Test   = 1
OTBR_AUTO_CREATE_NETWORK=0

###############################################################################
# Zigbee2MQTT - Optional
###############################################################################
ZIGBEE_DONGLE=/dev/ttyACM0

###############################################################################
# Tailscale / VPN - Optional
###############################################################################
TS_AUTHKEY=
TS_EXTRA_ARGS=
TS_USERSPACE=false

###############################################################################
# Bootstrap access
###############################################################################
# Autoinstall temporarily grants passwordless sudo to the lisa account. The
# bootstrap removes that grant after ensuring the account has a usable password.
LISA_ADMIN_USER=lisa
# Emergency/lab escape hatch. Production deployments should leave this at 0.
LISA_KEEP_PASSWORDLESS_SUDO=0
