[Unit]
Description=LISA Edge Docker Compose Stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/lisa-edge
ExecStart=/opt/lisa-edge/scripts/deploy.sh
ExecStop=/opt/lisa-edge/scripts/stop.sh
RemainAfterExit=yes
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
