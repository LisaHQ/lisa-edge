#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="$(basename "$0")"
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET" ;;
  esac
done
EDGE_REPO="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

# Colors: enabled only on interactive terminals; honor NO_COLOR (https://no-color.org).
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && [ "${TERM:-}" != "dumb" ]; then
  C_TITLE=$'\033[1;36m'   # bold cyan   - banner
  C_SECTION=$'\033[1;33m' # bold yellow - section headings
  C_CMD=$'\033[1;32m'     # bold green  - command names
  C_DIM=$'\033[2m'        # dim         - footnotes
  C_RESET=$'\033[0m'
else
  C_TITLE='' C_SECTION='' C_CMD='' C_DIM='' C_RESET=''
fi
if [ -t 2 ] && [ -z "${NO_COLOR:-}" ] && [ "${TERM:-}" != "dumb" ]; then
  C_ERR=$'\033[1;31m'     # bold red    - errors (stderr)
  C_ERR_RESET=$'\033[0m'
else
  C_ERR='' C_ERR_RESET=''
fi

usage() {
  cat <<USAGE
${C_TITLE}LISA Edge operator command${C_RESET}

${C_SECTION}Usage:${C_RESET}
  ${C_CMD}lisa-edge${C_RESET} <command> [arguments]

${C_SECTION}Setup and installation:${C_RESET}
  ${C_CMD}setup${C_RESET}                         Run the interactive first-boot workflow
  ${C_CMD}configure${C_RESET} [wizard options]    Write or update configuration only
  ${C_CMD}bootstrap${C_RESET} [arguments]         Prepare the host and deploy configured services
  ${C_CMD}usb list${C_RESET}                      List removable/USB disks
  ${C_CMD}usb build${C_RESET} <profile> [options] Download Ubuntu, write a bootable USB,
                                and inject the autoinstall profile
                                ${C_DIM}(asks which disk when --device is omitted)${C_RESET}
  ${C_CMD}usb prepare${C_RESET} <profile> <mount>  Inject the autoinstall profile on an
                                existing installer USB (production|rescue)

${C_SECTION}Runtime operations:${C_RESET}
  ${C_CMD}deploy${C_RESET} [--pull|--offline]      Start or refresh selected services
  ${C_CMD}stop${C_RESET}                           Stop selected services
  ${C_CMD}update${C_RESET} [clean]                 Fast-forward the repository and refresh images
                                ${C_DIM}(clean discards local changes to tracked files first)${C_RESET}
  ${C_CMD}health${C_RESET} [--strict]              Run readiness checks (HEALTHY/DEGRADED/FAILED)
  ${C_CMD}status${C_RESET}                         Show selected services and runtime state
  ${C_CMD}diagnostics${C_RESET} [output-dir]       Create a diagnostics bundle
  ${C_CMD}doctor matter-thread${C_RESET}          Focused Matter-over-Thread diagnostics
  ${C_CMD}service list${C_RESET}                  List available service selection keys

${C_SECTION}Thread border router (OTBR):${C_RESET}
  ${C_CMD}otbr status${C_RESET}                   Show OTBR runtime and Thread network state
  ${C_CMD}otbr dataset show${C_RESET}             Decoded dataset summary (secrets redacted)
  ${C_CMD}otbr dataset export${C_RESET} --output <file>  Export the dataset to a 0600 file
  ${C_CMD}otbr dataset backup${C_RESET} [--label <label>]  Back up the active dataset
  ${C_CMD}otbr dataset restore${C_RESET} <file>   Restore a dataset (network replacement)
  ${C_CMD}otbr network create${C_RESET}           Create a NEW Thread network (replaces the old one)

${C_SECTION}Matter server:${C_RESET}
  ${C_CMD}matter status${C_RESET}                 Show Matter server state (secret-safe)
  ${C_CMD}matter credentials list${C_RESET}       List stored Thread credential summaries
  ${C_CMD}matter thread status${C_RESET}          Compare stored credentials with OTBR
  ${C_CMD}matter thread sync${C_RESET} [options]  Store OTBR's dataset as a named credential
  ${C_CMD}matter thread remove${C_RESET} --id <id> Remove a stored Thread credential
  ${C_CMD}matter reset${C_RESET}                  Back up and wipe the Matter fabric (re-commission!)

${C_SECTION}Data protection:${C_RESET}
  ${C_CMD}backup${C_RESET}                         Create a production backup
  ${C_CMD}restore${C_RESET} [options] <archive>    Validate and restore a backup archive

${C_SECTION}Rescue layer:${C_RESET}
  ${C_CMD}rescue bootstrap${C_RESET}              Install rescue tools
  ${C_CMD}rescue doctor${C_RESET}                 Collect rescue-host diagnostics
  ${C_CMD}rescue disks${C_RESET}                  Inspect disks and installation candidates
  ${C_CMD}rescue mount${C_RESET} [arguments]      Mount the production filesystem
  ${C_CMD}rescue restore-backup${C_RESET} <file>  Safely restore a LISA Edge backup archive
  ${C_CMD}rescue restore-snapshot${C_RESET} ...   Restore a raw filesystem snapshot
  ${C_CMD}rescue reinstall${C_RESET}              Show the production reinstall procedure
  ${C_CMD}rescue update${C_RESET}                 Refresh installed rescue scripts

${C_SECTION}General:${C_RESET}
  ${C_CMD}help${C_RESET}                           Show this help

${C_DIM}Run \`lisa-edge <command> --help\` for command-specific options when supported.${C_RESET}
USAGE
}

die() {
  echo "${C_ERR}ERROR:${C_ERR_RESET} $*" >&2
  exit 2
}

run_script() {
  local label="$1"
  local relative="$2"
  shift 2
  [ -f "$EDGE_REPO/$relative" ] || die "$label is unavailable; missing $relative"
  exec bash "$EDGE_REPO/$relative" "$@"
}

run_rescue() {
  local action="${1:-}"
  [ -n "$action" ] || die "rescue requires a subcommand; run 'lisa-edge help'"
  shift

  case "$action" in
    bootstrap)
      run_script "rescue bootstrap" "rescue/scripts/bootstrap.sh" "$@" ;;
    doctor|diagnostics)
      run_script "rescue diagnostics" "rescue/scripts/diagnostics.sh" "$@" ;;
    disks)
      run_script "rescue disk detection" "rescue/scripts/detect-disks.sh" "$@" ;;
    mount)
      run_script "production filesystem mount" "rescue/scripts/mount-production.sh" "$@" ;;
    restore-backup)
      run_script "rescue backup restore" "rescue/scripts/restore-edge-backup.sh" "$@" ;;
    restore-snapshot)
      run_script "rescue filesystem snapshot restore" "rescue/scripts/restore-filesystem-snapshot.sh" "$@" ;;
    restore)
      die "ambiguous subcommand: use 'rescue restore-backup <archive>' or 'rescue restore-snapshot <snapshot-dir>'" ;;
    reinstall)
      run_script "production reinstall helper" "rescue/scripts/reinstall-guide.sh" "$@" ;;
    update)
      run_script "rescue script update" "rescue/scripts/update-rescue-scripts.sh" "$@" ;;
    *) die "unknown rescue subcommand: $action" ;;
  esac
}

run_usb() {
  local target="${1:-}"
  [ -n "$target" ] || die "usb requires 'list', 'build', or 'prepare'"
  shift

  case "$target" in
    list)
      run_script "USB disk listing" \
        "install/usb/scripts/build/build-ubuntu-usb.sh" list "$@" ;;
    build)
      run_script "USB build pipeline" \
        "install/usb/scripts/build/build-ubuntu-usb.sh" "$@" ;;
    prepare)
      local profile="${1:-}"
      [ -n "$profile" ] || die "usb prepare requires 'production' or 'rescue'"
      shift
      case "$profile" in
        production)
          run_script "production USB preparation" \
            "install/usb/scripts/prepare/prepare-production-usb.sh" "$@" ;;
        rescue)
          run_script "rescue USB preparation" \
            "install/usb/scripts/prepare/prepare-rescue-usb.sh" "$@" ;;
        *) die "unknown prepare profile: $profile (use 'production' or 'rescue')" ;;
      esac ;;
    production)
      # Deprecated alias for 'usb prepare production'; kept for compatibility.
      run_script "production USB preparation" \
        "install/usb/scripts/prepare/prepare-production-usb.sh" "$@" ;;
    rescue)
      # Deprecated alias for 'usb prepare rescue'; kept for compatibility.
      run_script "rescue USB preparation" \
        "install/usb/scripts/prepare/prepare-rescue-usb.sh" "$@" ;;
    *) die "unknown USB target: $target" ;;
  esac
}

run_otbr() {
  local action="${1:-}"
  [ -n "$action" ] || die "otbr requires a subcommand: status, dataset, or network"
  shift

  case "$action" in
    status)
      run_script "OTBR status" "services/otbr/status.sh" "$@" ;;
    dataset)
      local dataset_action="${1:-}"
      [ -n "$dataset_action" ] || die "otbr dataset requires a subcommand: show, export, backup, or restore"
      shift
      case "$dataset_action" in
        show)
          run_script "OTBR dataset summary" "services/otbr/dataset/show.sh" "$@" ;;
        export)
          run_script "OTBR dataset export" "services/otbr/dataset/export.sh" "$@" ;;
        backup)
          run_script "OTBR dataset backup" "services/otbr/dataset/backup.sh" "$@" ;;
        restore)
          run_script "OTBR dataset restore" "services/otbr/dataset/restore.sh" "$@" ;;
        *) die "unknown otbr dataset subcommand: $dataset_action" ;;
      esac ;;
    network)
      local network_action="${1:-}"
      [ -n "$network_action" ] || die "otbr network requires a subcommand: create"
      shift
      case "$network_action" in
        create)
          run_script "Thread network creation" "services/otbr/network-create.sh" "$@" ;;
        *) die "unknown otbr network subcommand: $network_action" ;;
      esac ;;
    *) die "unknown otbr subcommand: $action" ;;
  esac
}

run_matter() {
  local action="${1:-}"
  [ -n "$action" ] || die "matter requires a subcommand: status, credentials, thread, or reset"
  shift

  case "$action" in
    status)
      run_script "Matter status" "services/matter-server/status.sh" "$@" ;;
    credentials)
      run_script "Matter credentials" "services/matter-server/credentials.sh" "$@" ;;
    thread)
      run_script "Matter Thread credential management" \
        "services/matter-server/thread.sh" "$@" ;;
    reset)
      run_script "Matter fabric reset" "services/matter-server/data/reset.sh" "$@" ;;
    *) die "unknown matter subcommand: $action" ;;
  esac
}

run_doctor() {
  local topic="${1:-}"
  [ -n "$topic" ] || die "doctor requires a topic; currently supported: matter-thread"
  shift

  case "$topic" in
    matter-thread)
      run_script "Matter-over-Thread diagnostics" \
        "ops/diagnostics/doctor-matter-thread.sh" "$@" ;;
    *) die "unknown doctor topic: $topic" ;;
  esac
}

run_service() {
  local action="${1:-}"
  [ -n "$action" ] || die "service requires a subcommand; currently supported: list"
  shift

  case "$action" in
    list)
      run_script "service catalog listing" "services/list.sh" "$@" ;;
    *) die "unknown service subcommand: $action" ;;
  esac
}

if [ "$#" -eq 0 ] && [ "$PROGRAM_NAME" = "lisa-edge-provision" ]; then
  set -- setup
fi

if [ "$#" -eq 0 ]; then
  usage
  exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
  help|-h|--help) usage ;;
  setup) run_script "provisioning workflow" "install/provisioning/lisa-first-boot.sh" "$@" ;;
  configure) run_script "provisioning workflow" "install/provisioning/lisa-first-boot.sh" --mode config-only "$@" ;;
  bootstrap) run_script "host bootstrap" "install/bootstrap/bootstrap.sh" "$@" ;;
  deploy) run_script "deployment" "ops/deploy/deploy.sh" "$@" ;;
  stop) run_script "stop workflow" "ops/deploy/stop.sh" "$@" ;;
  update) run_script "update workflow" "ops/deploy/update.sh" "$@" ;;
  health) run_script "health check" "ops/deploy/healthcheck.sh" "$@" ;;
  status) run_script "status" "ops/deploy/status.sh" "$@" ;;
  diagnostics|diag) run_script "diagnostics" "ops/diagnostics/collect-diag.sh" "$@" ;;
  backup) run_script "backup" "ops/backup-restore/backup.sh" "$@" ;;
  restore) run_script "restore" "ops/backup-restore/restore.sh" "$@" ;;
  usb) run_usb "$@" ;;
  rescue) run_rescue "$@" ;;
  service) run_service "$@" ;;
  doctor) run_doctor "$@" ;;
  otbr) run_otbr "$@" ;;
  matter) run_matter "$@" ;;
  *)
    echo "${C_ERR}ERROR:${C_ERR_RESET} Unknown command: $COMMAND" >&2
    usage >&2
    exit 2
    ;;
esac
